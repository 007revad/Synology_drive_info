lun_cache_cached_read_only_desc	=	"<span class="orange-status">SSD-Cache {0} auf LUN ({1}) ist abgestürzt, doch auf die Daten kann noch zugegriffen werden, da der SSD-Cache schreibgeschützt ist.</span> Wir empfehlen, zu SSD-Cache {0} zu gehen und auf <div class="sm-pool-sug-more-btn-img"></div> > <b>Entfernen</b> zu klicken, um den SSD-Cache zu entfernen und dann einen neuen zu erstellen. Dies hat keine Auswirkung auf Ihre Daten."
lun_cache_contains_incompatible_drive_remove_cache_suggestion	=	"<span class="red-status">SSD-Cache {0} auf LUN {1} enthält eine oder mehrere SSDs, die sich nicht auf der <a href="https://www.synology.com/compatibility" class="link-font" target="_blank">Kompatibilitätsliste</a> befinden.</span> Diese SSDs können nicht verwendet werden und müssen sofort ausgetauscht werden. Diese _OSNAME_-Version unterstützt außerdem das Erstellen von SSD-Caches auf Block-Ebene-LUNs nicht mehr. Um die Block-Ebene-LUN weiterhin zu verwenden, entfernen Sie SSD-Cache {0} aus dem Speicher-Manager. Um einen neuen SSD-Cache mit kompatiblen SSDs zu erstellen, konvertieren Sie LUN ({1}) zu einer <a href="https://kb.synology.com/DSM/tutorial/Transfer_data_from_block_level_LUN" class="link-font" target="_blank">LUN auf Dateiebene</a>."
lun_cache_contains_incompatible_drive_with_apm_suggestion	=	"<span class="red-status">Der SSD-Cache auf LUN ({1}) enthält eine oder mehrere SSDs, die sich nicht auf der <a href="https://www.synology.com/compatibility" class="link-font" target="_blank">Kompatibilitätsliste</a> befinden.</span> Diese SSDs können nicht verwendet werden und müssen sofort ausgetauscht werden. Unter <span class="bold-font">SSD-Cache</span> sehen Sie die inkompatiblen oder nicht erkannten SSDs. Deaktivieren Sie diese anschließend und tauschen Sie jeweils eine SSD aus. Reparieren Sie den SSD-Cache jedes Mal, nachdem Sie eine SSD ausgetauscht haben. Wiederholen Sie den Vorgang, bis alle inkompatiblen oder nicht erkannten SSDs ersetzt wurden. Die I/O-Beschleunigung dieses SSD-Caches wird während der Reparatur deaktiviert. <a href="https://www.synology.com/knowledgebase/DSM/tutorial/Storage/Replace_incompatible_unverified_drives_v7" class="link-font" target="_blank">Weitere Informationen</a>"
lun_cache_contains_incompatible_drive_without_apm_suggestion	=	"<span class="red-status">Der SSD-Cache auf LUN ({1}) enthält eine oder mehrere SSDs, die sich nicht auf der <a href="https://www.synology.com/compatibility" class="link-font" target="_blank">Kompatibilitätsliste</a> befinden.</span> Diese SSDs können nicht verwendet werden und müssen sofort ausgetauscht werden. Unter <span class="bold-font">SSD-Cache</span> sehen Sie die inkompatiblen oder nicht erkannten SSDs. Deaktivieren Sie diese anschließend und tauschen Sie jeweils eine SSD aus. Reparieren Sie den SSD-Cache jedes Mal, nachdem Sie eine SSD ausgetauscht haben. Wiederholen Sie den Vorgang, bis alle inkompatiblen oder nicht erkannten SSDs ersetzt wurden. <a href="https://www.synology.com/knowledgebase/DSM/tutorial/Storage/Replace_incompatible_unverified_drives_v7" class="link-font" target="_blank">Weitere Informationen</a>"
